---
import { Image } from "astro:assets";
import logoIronPulse from "../assets/brand/logo-ironpulse.webp";
import ThemeToggle from "./common/ThemeToggle.astro";
---

<nav class="navbar" aria-label="Navegación principal">
  <a href="/" class="navbar-logo">
    <Image
      src={logoIronPulse}
      alt="Iron Pulse Gym"
      loading="eager"
      format="webp"
      width={600}
      height={557}
      widths={[150, 330, 600]}
      sizes="(max-width: 900px) 150px, 330px"
    />
  </a>
  <button
    class="hamburger-menu"
    id="hamburger-menu"
    aria-controls="nav-links"
    aria-expanded="false"
    aria-label="Abrir menú de navegación"
  >
    <span aria-hidden="true"></span>
    <span aria-hidden="true"></span>
    <span aria-hidden="true"></span>
  </button>
  <ul id="nav-links" class="nav-links" role="list">
    <li><a href="#inicio">Inicio</a></li>
    <li><a href="#conocenos">Conócenos</a></li>
    <li><a href="#servicios">Servicios</a></li>
    <li><a href="#sucursal">Sucursal</a></li>
  </ul>
  <ThemeToggle />
</nav>

<script>
  import { initMobileMenu } from "../scripts/navbar-menu";
  import { initActiveNav } from "../scripts/active-nav";

  const disconnectMobile = initMobileMenu();
  const disconnectNav = initActiveNav();

  function cleanup() {
    disconnectMobile();
    disconnectNav();
    document.removeEventListener("astro:before-swap", cleanup);
  }

  document.addEventListener("astro:before-swap", cleanup);
</script>

<style>
  .navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    box-sizing: border-box;
    background-color: var(--color-bg);
    height: 90px;
    padding: 0 4rem;
  }

  .navbar-logo {
    will-change: transform;
    transition: transform 0.3s var(--ease-spring);
    margin-top: 288px;
    margin-left: 4rem;
  }

  .navbar-logo:hover {
    transform: scale(1.02);
  }

  .navbar-logo img {
    width: 330px;
    aspect-ratio: 600 / 557;
  }

  .hamburger-menu {
    display: none;
    flex-direction: column;
    justify-content: space-around;
    width: 30px;
    height: 25px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 60;
  }

  .hamburger-menu:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 4px;
    border-radius: 4px;
  }

  .hamburger-menu span {
    width: 30px;
    height: 3px;
    background: var(--color-text-base);
    border-radius: 10px;
    transform-origin: center;
  }

  .hamburger-menu.is-open span:nth-child(1) {
    transform: rotate(45deg) translate(8px, 8px);
    background: var(--color-primary);
  }

  .hamburger-menu.is-open span:nth-child(2) {
    opacity: 0;
  }

  .hamburger-menu.is-open span:nth-child(3) {
    transform: rotate(-45deg) translate(7px, -7px);
    background: var(--color-primary);
  }

  .nav-links {
    display: flex;
    gap: 3rem;
    list-style: none;
    margin: 0 1.5rem 0 auto;
    padding: 0;
    align-items: center;
    height: 100%;
    padding-top: 0.5rem;
  }

  .nav-links a {
    color: var(--color-text-base);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color 0.2s ease;
    position: relative;
  }

  .nav-links a::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--color-primary);
    transform: scaleX(0);
    transition: transform 0.2s var(--ease-spring);
  }

  .nav-links a:hover,
  .nav-links a:focus-visible {
    color: var(--color-primary);
  }

  .nav-links a:hover::after,
  .nav-links a:focus-visible::after,
  .nav-links a.active::after {
    transform: scaleX(1);
  }

  .nav-links a.active {
    color: var(--color-primary);
  }

  @media (prefers-reduced-motion: no-preference) {
    .hamburger-menu span {
      transition: all 0.3s var(--ease-spring);
    }
  }

  @media (max-width: 1399px) {
    .navbar-logo img {
      width: 150px;
    }
  }

  @media (max-width: 768px) {
    .navbar {
      padding: 0 2rem;
      min-height: 80px;
      height: auto;
    }

    .navbar-logo {
      margin-top: 64px;
      margin-left: 5rem;
    }

    .navbar-logo img {
      width: 120px;
    }

    .hamburger-menu {
      display: flex;
    }

    .nav-links {
      position: absolute;
      top: 100%;
      right: 1.5rem;
      width: 200px;
      flex-direction: column;
      background-color: var(--color-surface);
      padding: 1.5rem;
      gap: 1rem;
      border-radius: 0.75rem;
      border: 1px solid color-mix(in srgb, var(--color-primary) 20%, transparent);
      transform: scale(0.95);
      opacity: 0;
      pointer-events: none;
      z-index: 40;
      height: auto;
      align-items: stretch;
      padding-top: 1.5rem;
    }

    .nav-links.is-open {
      transform: scale(1);
      opacity: 1;
      pointer-events: auto;
    }

    @media (prefers-reduced-motion: no-preference) {
      .nav-links {
        transition:
          transform 0.3s var(--ease-spring),
          opacity 0.3s var(--ease-spring);
      }
    }

    .nav-links a {
      font-size: 0.9rem;
      padding: 0.75rem 1rem;
      border-radius: 0.5rem;
      transition:
        background-color 0.2s ease,
        color 0.2s ease;
      text-align: center;
    }

    .nav-links a::after {
      display: none;
    }

    .nav-links a:hover,
    .nav-links a:focus-visible {
      background-color: color-mix(in srgb, var(--color-primary) 10%, transparent);
      color: var(--color-primary);
    }

    .nav-links a.active {
      background-color: color-mix(in srgb, var(--color-primary) 10%, transparent);
    }
  }
</style>

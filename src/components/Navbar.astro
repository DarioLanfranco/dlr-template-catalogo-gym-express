---
import { Image } from "astro:assets";
import logoIronPulse from "../assets/brand/logo-ironpulse.webp";
---

<nav class="navbar" aria-label="Navegación principal">
  <a href="/" class="navbar-logo">
    <Image
      src={logoIronPulse}
      alt="Iron Pulse Gym"
      loading="eager"
      format="webp"
      width={600}
      height={557}
      widths={[150, 330, 600]}
      sizes="(max-width: 900px) 150px, 330px"
    />
  </a>
  <button
    class="hamburger-menu"
    id="hamburger-menu"
    aria-controls="nav-links"
    aria-expanded="false"
    aria-label="Abrir menú de navegación"
  >
    <span aria-hidden="true"></span>
    <span aria-hidden="true"></span>
    <span aria-hidden="true"></span>
  </button>
  <ul id="nav-links" class="nav-links" role="list">
    <li><a href="#inicio">Inicio</a></li>
    <li><a href="#conocenos">Conócenos</a></li>
    <li><a href="#servicios">Servicios</a></li>
    <li><a href="#sucursal">Sucursal</a></li>
  </ul>
</nav>

<script>
  const hamburgerButton = document.getElementById("hamburger-menu");
  const navLinks = document.getElementById("nav-links");
  const body = document.body;

  function isMenuOpen() {
    return hamburgerButton?.getAttribute("aria-expanded") === "true";
  }

  function openMenu() {
    hamburgerButton?.classList.add("is-open");
    navLinks?.classList.add("is-open");
    hamburgerButton?.setAttribute("aria-expanded", "true");
    hamburgerButton?.setAttribute("aria-label", "Cerrar menú de navegación");
    body.classList.add("nav-open");

    // Focus first link
    const firstLink = navLinks?.querySelector("a");
    if (firstLink) {
      firstLink.focus({ preventScroll: true });
    }
  }

  function closeMenu() {
    hamburgerButton?.classList.remove("is-open");
    navLinks?.classList.remove("is-open");
    hamburgerButton?.setAttribute("aria-expanded", "false");
    hamburgerButton?.setAttribute("aria-label", "Abrir menú de navegación");
    body.classList.remove("nav-open");

    // Return focus to hamburger button
    hamburgerButton?.focus({ preventScroll: true });
  }

  function toggleMenu() {
    if (isMenuOpen()) {
      closeMenu();
    } else {
      openMenu();
    }
  }

  if (hamburgerButton && navLinks) {
    hamburgerButton.addEventListener("click", toggleMenu);

    // Close menu when clicking on any link
    const links = navLinks.querySelectorAll("a");
    links.forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    // Close on Escape key
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && isMenuOpen()) {
        closeMenu();
      }
    });

    // Close on click outside
    document.addEventListener("click", (e) => {
      const target = e.target as Node;

      if (
        isMenuOpen() &&
        !navLinks.contains(target) &&
        !hamburgerButton.contains(target)
      ) {
        closeMenu();
      }
    });

    // Trap focus within mobile menu
    navLinks.addEventListener("keydown", (e) => {
      if (e.key === "Tab" && isMenuOpen()) {
        const focusable = navLinks.querySelectorAll<HTMLElement>(
          'a, button, input, select, textarea, [tabindex]:not([tabindex="-1"])',
        );
        const first = focusable[0];
        const last = focusable[focusable.length - 1];

        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last?.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first?.focus();
        }
      }
    });
  }
</script>

<style>
  .navbar {
    padding: 0 4rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    box-sizing: border-box;
    background-color: var(--color-primary);
    height: 90px;
    position: relative;
  }

  .navbar-logo {
    display: flex;
    align-items: center;
    z-index: 50;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    margin-left: 4rem;
    margin-top: 18rem;
  }

  .navbar-logo:hover {
    transform: scale(1.02);
  }

  .navbar-logo img {
    width: 330px;
    aspect-ratio: 1550 / 1440;
    display: flex;
  }

  .hamburger-menu {
    display: none;
    flex-direction: column;
    justify-content: space-around;
    width: 30px;
    height: 25px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 60;
  }

  .hamburger-menu:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
    border-radius: 4px;
  }

  .hamburger-menu span {
    width: 30px;
    height: 3px;
    background: #ffffff;
    border-radius: 10px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: center;
  }

  .hamburger-menu.is-open span:nth-child(1) {
    transform: rotate(45deg) translate(8px, 8px);
    background: var(--color-accent);
  }

  .hamburger-menu.is-open span:nth-child(2) {
    opacity: 0;
  }

  .hamburger-menu.is-open span:nth-child(3) {
    transform: rotate(-45deg) translate(7px, -7px);
    background: var(--color-accent);
  }

  .nav-links {
    display: flex;
    gap: 3rem;
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
    height: 100%;
    padding-top: 0.5rem;
  }

  .nav-links a {
    color: #ffffff;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color 0.2s ease;
    position: relative;
  }

  .nav-links a::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-links a:hover,
  .nav-links a:focus-visible {
    color: var(--color-accent);
  }

  .nav-links a:hover::after,
  .nav-links a:focus-visible::after,
  .nav-links a.active::after {
    transform: scaleX(1);
  }

  .nav-links a.active {
    color: var(--color-accent);
  }

  @media (min-width: 901px) and (max-width: 1400px) {
    .navbar-logo img {
      width: 150px;
      left: 15rem;
      margin-bottom: 10rem;
    }
  }

  @media (max-width: 900px) {
    .navbar {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      padding: 0 2rem;
      min-height: 80px;
    }

    .navbar-logo {
      margin-left: 5rem;
      margin-top: 4rem;
    }

    .navbar-logo img {
      width: 120px;
    }

    .hamburger-menu {
      display: flex;
    }

    .nav-links {
      position: absolute;
      top: 100%;
      right: 1.5rem;
      width: 200px;
      flex-direction: column;
      background-color: #1a1a1a;
      padding: 1.5rem;
      gap: 1rem;
      border-radius: 0.75rem;
      border: 1px solid rgba(255, 159, 28, 0.2);
      transform: scale(0.95);
      opacity: 0;
      pointer-events: none;
      transition:
        transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
        opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      z-index: 40;
      height: auto;
      align-items: stretch;
      padding-top: 1.5rem;
    }

    .nav-links.is-open {
      transform: scale(1);
      opacity: 1;
      pointer-events: auto;
    }

    .nav-links a {
      font-size: 0.9rem;
      padding: 0.75rem 1rem;
      border-radius: 0.5rem;
      transition:
        background-color 0.2s ease,
        color 0.2s ease;
      text-align: center;
    }

    .nav-links a::after {
      display: none;
    }

    .nav-links a:hover,
    .nav-links a:focus-visible {
      background-color: rgba(255, 159, 28, 0.1);
      color: var(--color-accent);
    }

    .nav-links a.active {
      background-color: rgba(255, 159, 28, 0.1);
    }
  }
</style>

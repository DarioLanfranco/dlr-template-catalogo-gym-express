---
import { Image } from "astro:assets";
import logoIronPulse from "../assets/brand/logo-ironpulse.webp";
---

<nav class="navbar" aria-label="Navegación principal">
  <a href="/" class="navbar-logo">
    <Image
      src={logoIronPulse}
      alt="Iron Pulse Gym"
      loading="eager"
      format="webp"
      width={600}
      height={557}
      widths={[150, 330, 600]}
      sizes="(max-width: 900px) 150px, 330px"
    />
  </a>
  <button
    class="hamburger-menu"
    id="hamburger-menu"
    aria-controls="nav-links"
    aria-expanded="false"
    aria-label="Abrir menú de navegación"
  >
    <span aria-hidden="true"></span>
    <span aria-hidden="true"></span>
    <span aria-hidden="true"></span>
  </button>
  <ul id="nav-links" class="nav-links" role="list">
    <li><a href="#inicio">Inicio</a></li>
    <li><a href="#conocenos">Conócenos</a></li>
    <li><a href="#servicios">Servicios</a></li>
    <li><a href="#sucursal">Sucursal</a></li>
  </ul>
  <button
    id="theme-toggle"
    class="theme-toggle"
    aria-label="Cambiar tema"
    type="button"
  >
    <svg
      class="theme-toggle-icon theme-toggle-sun"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="12" cy="12" r="5"></circle>
      <line x1="12" y1="1" x2="12" y2="3"></line>
      <line x1="12" y1="21" x2="12" y2="23"></line>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
      <line x1="1" y1="12" x2="3" y2="12"></line>
      <line x1="21" y1="12" x2="23" y2="12"></line>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
    </svg>
    <svg
      class="theme-toggle-icon theme-toggle-moon"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
    </svg>
  </button>
</nav>

<script>
  const hamburgerButton = document.getElementById("hamburger-menu");
  const navLinks = document.getElementById("nav-links");
  const themeToggle = document.getElementById("theme-toggle");
  const body = document.body;

  function applyTheme(theme: any) {
    document.documentElement.setAttribute("data-theme", theme);
    localStorage.setItem("theme", theme);
  }

  function toggleTheme() {
    const current = document.documentElement.getAttribute("data-theme");
    applyTheme(current === "light" ? "dark" : "light");
  }

  if (themeToggle) {
    themeToggle.addEventListener("click", toggleTheme);
  }

  function isMenuOpen() {
    return hamburgerButton?.getAttribute("aria-expanded") === "true";
  }

  function openMenu() {
    hamburgerButton?.classList.add("is-open");
    navLinks?.classList.add("is-open");
    hamburgerButton?.setAttribute("aria-expanded", "true");
    hamburgerButton?.setAttribute("aria-label", "Cerrar menú de navegación");
    body.classList.add("nav-open");

    const firstLink = navLinks?.querySelector("a");
    if (firstLink) {
      firstLink.focus({ preventScroll: true });
    }
  }

  function closeMenu() {
    hamburgerButton?.classList.remove("is-open");
    navLinks?.classList.remove("is-open");
    hamburgerButton?.setAttribute("aria-expanded", "false");
    hamburgerButton?.setAttribute("aria-label", "Abrir menú de navegación");
    body.classList.remove("nav-open");

    hamburgerButton?.focus({ preventScroll: true });
  }

  function toggleMenu() {
    if (isMenuOpen()) {
      closeMenu();
    } else {
      openMenu();
    }
  }

  function handleEscape(e: KeyboardEvent) {
    if (e.key === "Escape" && isMenuOpen()) {
      closeMenu();
    }
  }

  function handleClickOutside(e: MouseEvent) {
    const target = e.target as Node;
    if (
      isMenuOpen() &&
      !navLinks?.contains(target) &&
      !hamburgerButton?.contains(target)
    ) {
      closeMenu();
    }
  }

  function handleTabTrap(e: KeyboardEvent) {
    if (e.key === "Tab" && isMenuOpen()) {
      const focusable = navLinks?.querySelectorAll<HTMLElement>(
        'a, button, input, select, textarea, [tabindex]:not([tabindex="-1"])',
      );
      if (!focusable || focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];

      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last?.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first?.focus();
      }
    }
  }

  const sectionObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const navLinks =
            document.querySelectorAll<HTMLAnchorElement>(".nav-links a");
          navLinks.forEach((link) => {
            const isActive =
              link.getAttribute("href") === `#${entry.target.id}`;
            link.classList.toggle("active", isActive);
          });
        }
      });
    },
    { threshold: 0.3 },
  );

  const sections = document.querySelectorAll("section[id]");
  if (sections.length) {
    sections.forEach((section) => sectionObserver.observe(section));
  }

  function cleanup() {
    if (hamburgerButton) {
      hamburgerButton.removeEventListener("click", toggleMenu);
    }
    if (themeToggle) {
      themeToggle.removeEventListener("click", toggleTheme);
    }
    document.removeEventListener("keydown", handleEscape);
    document.removeEventListener("click", handleClickOutside);
    if (navLinks) {
      navLinks.querySelectorAll("a").forEach((link) => {
        link.removeEventListener("click", closeMenu);
      });
      navLinks.removeEventListener("keydown", handleTabTrap);
    }
    sectionObserver.disconnect();
    document.removeEventListener("astro:before-swap", cleanup);
  }

  if (hamburgerButton && navLinks) {
    hamburgerButton.addEventListener("click", toggleMenu);

    navLinks.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    document.addEventListener("keydown", handleEscape);
    document.addEventListener("click", handleClickOutside);
    navLinks.addEventListener("keydown", handleTabTrap);

    document.addEventListener("astro:before-swap", cleanup);
  }
</script>

<style>
  .navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    box-sizing: border-box;
    background-color: var(--color-primary);
    height: 90px;
    padding: 0 4rem;
  }

  .navbar-logo {
    will-change: transform;
    transition: transform 0.3s var(--ease-spring);
    margin-top: var(--logo-offset-y, 288px);
    margin-left: var(--logo-offset-x, 4rem);
  }

  .navbar-logo:hover {
    transform: scale(1.02);
  }

  .navbar-logo img {
    width: 330px;
    aspect-ratio: 600 / 557;
  }

  .hamburger-menu {
    display: none;
    flex-direction: column;
    justify-content: space-around;
    width: 30px;
    height: 25px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 60;
  }

  .hamburger-menu:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
    border-radius: 4px;
  }

  .hamburger-menu span {
    width: 30px;
    height: 3px;
    background: var(--color-background);
    border-radius: 10px;
    transform-origin: center;
  }

  .hamburger-menu.is-open span:nth-child(1) {
    transform: rotate(45deg) translate(8px, 8px);
    background: var(--color-accent);
  }

  .hamburger-menu.is-open span:nth-child(2) {
    opacity: 0;
  }

  .hamburger-menu.is-open span:nth-child(3) {
    transform: rotate(-45deg) translate(7px, -7px);
    background: var(--color-accent);
  }

  .nav-links {
    display: flex;
    gap: 3rem;
    list-style: none;
    margin: 0 1.5rem 0 auto;
    padding: 0;
    align-items: center;
    height: 100%;
    padding-top: 0.5rem;
  }

  .nav-links a {
    color: var(--color-background);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color 0.2s ease;
    position: relative;
  }

  .nav-links a::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transition: transform 0.2s var(--ease-spring);
  }

  .nav-links a:hover,
  .nav-links a:focus-visible {
    color: var(--color-accent);
  }

  .nav-links a:hover::after,
  .nav-links a:focus-visible::after,
  .nav-links a.active::after {
    transform: scaleX(1);
  }

  .nav-links a.active {
    color: var(--color-accent);
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 2px solid var(--color-background);
    border-radius: 0.5rem;
    color: var(--color-background);
    cursor: pointer;
    padding: 0.4rem;
    width: 36px;
    height: 36px;
    transition:
      border-color 0.2s var(--ease-spring),
      color 0.2s var(--ease-spring),
      transform 0.2s var(--ease-spring);
    flex-shrink: 0;
  }

  .theme-toggle:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    transform: scale(1.1);
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
    border-radius: 0.5rem;
  }

  :global([data-theme="dark"]) .theme-toggle-sun {
    display: block;
  }

  :global([data-theme="dark"]) .theme-toggle-moon {
    display: none;
  }

  :global([data-theme="light"]) .theme-toggle-sun {
    display: none;
  }

  :global([data-theme="light"]) .theme-toggle-moon {
    display: block;
  }

  :global(:root:not([data-theme])) .theme-toggle-sun {
    display: block;
  }

  :global(:root:not([data-theme])) .theme-toggle-moon {
    display: none;
  }

  .theme-toggle-icon {
    width: 20px;
    height: 20px;
  }

  /*
   * Accessibility: Respect OS-level motion preference (WCAG 2.1 SC 2.3.3).
   * Hamburger lines and mobile menu only animate when the user has NOT
   * requested reduced motion. Otherwise the transitions are instant.
   */
  @media (prefers-reduced-motion: no-preference) {
    .hamburger-menu span {
      transition: all 0.3s var(--ease-spring);
    }
  }

  /* Tablet (<= 1399px): overrides desktop default */
  @media (max-width: 1399px) {
    .navbar-logo img {
      width: 150px;
    }
  }

  /* Mobile (<= 768px): overrides tablet */
  @media (max-width: 768px) {
    .navbar {
      padding: 0 2rem;
      min-height: 80px;
      height: auto;
    }

    .navbar-logo {
      --logo-offset-y: 64px;
      --logo-offset-x: 5rem;
    }

    .navbar-logo img {
      width: 120px;
    }

    .hamburger-menu {
      display: flex;
    }

    .theme-toggle {
      margin-left: auto;
      margin-right: 1rem;
    }

    .nav-links {
      position: absolute;
      top: 100%;
      right: 1.5rem;
      width: 200px;
      flex-direction: column;
      background-color: var(--color-surface);
      padding: 1.5rem;
      gap: 1rem;
      border-radius: 0.75rem;
      border: 1px solid rgba(255, 159, 28, 0.2);
      transform: scale(0.95);
      opacity: 0;
      pointer-events: none;
      z-index: 40;
      height: auto;
      align-items: stretch;
      padding-top: 1.5rem;
    }

    .nav-links.is-open {
      transform: scale(1);
      opacity: 1;
      pointer-events: auto;
    }

    @media (prefers-reduced-motion: no-preference) {
      .nav-links {
        transition:
          transform 0.3s var(--ease-spring),
          opacity 0.3s var(--ease-spring);
      }
    }

    .nav-links a {
      font-size: 0.9rem;
      padding: 0.75rem 1rem;
      border-radius: 0.5rem;
      transition:
        background-color 0.2s ease,
        color 0.2s ease;
      text-align: center;
    }

    .nav-links a::after {
      display: none;
    }

    .nav-links a:hover,
    .nav-links a:focus-visible {
      background-color: rgba(255, 159, 28, 0.1);
      color: var(--color-accent);
    }

    .nav-links a.active {
      background-color: rgba(255, 159, 28, 0.1);
    }
  }
</style>

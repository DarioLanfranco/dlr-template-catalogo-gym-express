---
import { Image } from "astro:assets";
import coachs1 from "../../assets/images/coachs1.webp";

interface Props {
  subtitle: string;
  title: string;
  text1: string;
  text2: string;
}

const { subtitle, title, text1, text2 } = Astro.props;
---

<section id="conocenos" class="about reveal-on-scroll">
  <div class="about-content">
    <div class="about-text">
      <p class="subtitle reveal-on-scroll">{subtitle}</p>
      <h2 class="reveal-on-scroll">{title.toUpperCase()}</h2>
      <p class="reveal-on-scroll">{text1}</p>
      <p class="reveal-on-scroll">{text2}</p>
    </div>
    <div class="about-image reveal-on-scroll media-card">
      <Image
        src={coachs1}
        alt="Historia de Iron Pulse Gym"
        width={800}
        height={600}
        loading="lazy"
      />
    </div>
  </div>
</section>

<style>
  .about {
    padding: 6rem 2rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .about-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .about-text .subtitle {
    font-size: 1.125rem;
    font-style: italic;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .about-text h2 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 2rem;
    color: var(--color-background);
    letter-spacing: 0.05em;
  }

  .about-text p {
    font-size: 1.125rem;
    line-height: 1.8;
    margin-bottom: 1.5rem;
    color: var(--color-background);
    opacity: 0.9;
  }

  .about-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 1399px) {
    .about {
      padding: 4rem 2rem;
    }

    .about-content {
      gap: 2.5rem;
    }

    .about-text h2 {
      font-size: 2.25rem;
    }
  }

  @media (max-width: 768px) {
    .about {
      padding: 4rem 1.5rem;
    }

    .about-content {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .about-text h2 {
      font-size: 2rem;
    }
  }
</style>

---
interface Props {
  siteName: string;
}

const { siteName } = Astro.props;
---

<footer>
  <p>
    &copy; 2026 Copyright {siteName}. Todos los derechos
    reservados. Desarrollado por Dario Lanfranco
  </p>
</footer>

<style>
  footer {
    padding: 2rem;
    text-align: center;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  footer p {
    color: var(--color-background);
    opacity: 0.7;
    font-size: 0.875rem;
  }
</style>

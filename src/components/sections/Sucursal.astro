---
import facebookIcon from "../../assets/brand/icons/facebook.svg";
import instagramIcon from "../../assets/brand/icons/instagram.svg";
import xIcon from "../../assets/brand/icons/x.svg";
import CTAButton from "../common/CTAButton.astro";

interface Props {
  businessHours: string;
  address: string;
  googleMapsLink: string;
  facebookUrl: string;
  instagramUrl: string;
  xUrl?: string;
}

const { businessHours, address, googleMapsLink, facebookUrl, instagramUrl, xUrl } = Astro.props;
---

<section id="sucursal" class="sucursal reveal-on-scroll">
  <h2 class="reveal-on-scroll">Información de Sucursal</h2>
  <div class="sucursal-content">
    <div class="sucursal-item reveal-on-scroll">
      <h3>Horarios</h3>
      <p>{businessHours}</p>
    </div>
    <div class="sucursal-item reveal-on-scroll">
      <h3>Ubicación</h3>
      <p>{address}</p>
      <CTAButton
        href={googleMapsLink}
        variant="secondary"
        target="_blank"
        rel="noopener noreferrer"
      >
        Ver en Google Maps
      </CTAButton>
    </div>
    <div class="sucursal-item reveal-on-scroll">
      <h3>Redes Sociales</h3>
      <div class="redes-content">
        <a
          href={facebookUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="redes-link"
          aria-label="Facebook"
        >
          <img
            src={facebookIcon.src}
            alt=""
            width="48"
            height="48"
            loading="lazy"
          />
        </a>
        <a
          href={instagramUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="redes-link"
          aria-label="Instagram"
        >
          <img
            src={instagramIcon.src}
            alt=""
            width="48"
            height="48"
            loading="lazy"
          />
        </a>
        {xUrl && (
          <a
            href={xUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="redes-link"
            aria-label="X"
          >
            <img
              src={xIcon.src}
              alt=""
              width="48"
              height="48"
              loading="lazy"
            />
          </a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .sucursal {
    padding: 6rem 2rem 4rem;
    max-width: 1400px;
    margin: 0 auto;
    text-align: center;
  }

  .sucursal h2 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 3rem;
    text-align: center;
    color: var(--color-background);
  }

  .sucursal-content {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2.5rem;
  }

  .sucursal-item {
    text-align: center;
    flex: 0 1 280px;
  }

  .sucursal-item h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: var(--color-accent);
  }

  .sucursal-item p {
    margin-bottom: 1.5rem;
    color: var(--color-background);
    opacity: 0.9;
  }

  .redes-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .redes-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    transition:
      transform 0.2s var(--ease-spring),
      opacity 0.2s var(--ease-spring);
    border-radius: 0.5rem;
  }

  .redes-link:hover {
    transform: scale(1.1);
    opacity: 0.85;
  }

  .redes-link:focus-visible {
    outline: 2px solid #ff9f1c;
    outline-offset: 4px;
  }

  .redes-link img {
    width: 48px;
    height: 48px;
    display: block;
  }

  @media (max-width: 1399px) {
    .sucursal {
      padding: 4rem 2rem 2rem;
    }

    .sucursal h2 {
      font-size: 2.25rem;
    }

    .sucursal-content {
      gap: 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .sucursal {
      padding: 4rem 1.5rem 2rem;
    }

    .sucursal h2 {
      font-size: 2rem;
    }

    .sucursal-content {
      flex-direction: column;
      align-items: center;
    }

    .sucursal-item {
      flex: none;
    }
  }
</style>

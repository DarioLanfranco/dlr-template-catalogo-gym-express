---
import { siteConfig } from "../../config/site-config";
import { Image } from "astro:assets";
import coachs1 from "../../assets/images/coachs1.webp";
import spinning1 from "../../assets/images/spinning1.webp";
import pilates1 from "../../assets/images/pilates1.webp";
import gym12 from "../../assets/images/gym12.webp";

const serviceImages = {
  "coachs1.webp": coachs1,
  "spinning1.webp": spinning1,
  "pilates1.webp": pilates1,
  "gym12.webp": gym12,
};
---

<section id="servicios" class="services reveal-on-scroll">
  <h2 class="reveal-on-scroll">Nuestros Servicios</h2>
  <div class="services-grid">
    {
      siteConfig.services.map((service) => (
        <article class="service-card reveal-on-scroll" id={service.id}>
          <Image
            src={serviceImages[service.image as keyof typeof serviceImages]}
            alt={service.title}
            width={600}
            height={450}
            loading="lazy"
            class="service-card-image"
          />
          <div class="service-card-overlay">
            <h3>{service.title}</h3>
            <p>{service.description}</p>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .services {
    padding: 6rem 2rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .services h2 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 3rem;
    text-align: center;
    color: var(--color-background);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .service-card {
    position: relative;
    border-radius: 1.5rem;
    aspect-ratio: 4/3;
    overflow: hidden;
    transition: transform 0.3s var(--ease-spring, cubic-bezier(0.4, 0, 0.2, 1));
  }

  .service-card:hover {
    transform: scale(1.05);
  }

  .service-card-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s var(--ease-spring, cubic-bezier(0.4, 0, 0.2, 1));
  }

  .service-card:hover .service-card-image {
    transform: scale(1.05);
  }

  .service-card-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.9),
      rgba(0, 0, 0, 0.4),
      transparent
    );
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 2rem;
  }

  .service-card h3 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: #ffffff;
  }

  .service-card p {
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .services {
      padding: 4rem 1.5rem;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

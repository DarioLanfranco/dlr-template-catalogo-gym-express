---
import { Image } from "astro:assets";
import coachs1 from "../../assets/images/coachs1.webp";

interface Service {
  id: string;
  title: string;
  description: string;
  image: string;
}

interface Props {
  services: Service[];
}

const { services } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/*.webp",
  { eager: true },
);

const serviceImages = Object.fromEntries(
  Object.entries(images).map(([path, module]) => [
    path.split("/").pop(),
    module.default,
  ]),
);
---

<section id="servicios" class="services reveal-on-scroll">
  <h2 class="reveal-on-scroll">Nuestros Servicios</h2>
  <div class="services-grid">
    {
      services.map((service) => (
        <article class="service-card reveal-on-scroll media-card" id={service.id}>
          <Image
            src={serviceImages[service.image] ?? coachs1}
            alt={service.title}
            width={600}
            height={450}
            format="webp"
            quality={75}
            loading="lazy"
            class="service-card-image"
          />
          <div class="service-card-overlay">
            <h3>{service.title}</h3>
            <p>{service.description}</p>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .services {
    padding: 6rem 2rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .services h2 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 3rem;
    text-align: center;
    color: var(--color-background);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .service-card {
    position: relative;
  }

  .service-card:hover {
    transform: scale(1.05);
  }

  .service-card-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s var(--ease-spring);
  }

  .service-card:hover .service-card-image {
    transform: scale(1.05);
  }

  .service-card-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to top,
      var(--service-overlay-start),
      var(--service-overlay-mid),
      transparent
    );
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 2rem;
  }

  .service-card h3 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--service-text);
  }

  .service-card p {
    color: var(--service-text-muted);
    line-height: 1.6;
  }

  @media (max-width: 1399px) {
    .services {
      padding: 4rem 2rem;
    }

    .services h2 {
      font-size: 2.25rem;
    }
  }

  @media (max-width: 768px) {
    .services {
      padding: 4rem 1.5rem;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

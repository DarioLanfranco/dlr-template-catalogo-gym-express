---
import { siteConfig } from "../../config/site-config";
import { Image } from "astro:assets";
import gymHero from "../../assets/images/gym1.webp";
import gymHero2 from "../../assets/images/gym14.webp";
import gymHero3 from "../../assets/images/gym15.webp";
---

<section id="inicio" class="hero">
  <div class="hero-content">
    <h2>{siteConfig.tagline}</h2>
    <p>{siteConfig.description}</p>
    <a href="#servicios" class="cta-button">Ver Servicios</a>
  </div>
  <div class="hero-grid">
    <div class="hero-image hero-image-primary">
      <Image
        src={gymHero}
        alt="Gym interior"
        width={800}
        height={600}
        widths={[400, 728, 800]}
        format="webp"
        quality={75}
        loading="eager"
      />
    </div>
    <div class="hero-image hero-image-secondary">
      <Image
        src={gymHero2}
        alt="Training equipment"
        width={400}
        height={300}
        loading="lazy"
      />
    </div>
    <div class="hero-image hero-image-tertiary">
      <Image
        src={gymHero3}
        alt="Gym atmosphere"
        width={400}
        height={300}
        widths={[400, 728, 800]}
        format="webp"
        quality={75}
        loading="lazy"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    padding: 6rem 2rem;
    max-width: 1400px;
    margin: 0 auto;
    align-items: center;
    background: linear-gradient(
      135deg,
      rgba(18, 18, 18, 0.95),
      rgba(18, 18, 18, 0.85)
    );
    border-radius: 1rem;
  }

  .hero-content h2 {
    font-size: 3rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    line-height: 1.2;
    color: var(--color-background);
  }

  .hero-content p {
    font-size: 1.25rem;
    margin-bottom: 2rem;
    color: var(--color-background);
    opacity: 0.9;
  }

  .cta-button {
    display: inline-block;
    background-color: var(--color-accent);
    color: var(--color-primary);
    padding: 1rem 2rem;
    font-weight: 600;
    border-radius: 0.5rem;
    transition:
      transform 0.2s var(--ease-spring, cubic-bezier(0.4, 0, 0.2, 1)),
      opacity 0.2s var(--ease-spring, cubic-bezier(0.4, 0, 0.2, 1)),
      box-shadow 0.2s var(--ease-spring, cubic-bezier(0.4, 0, 0.2, 1)),
      border-color 0.2s var(--ease-spring, cubic-bezier(0.4, 0, 0.2, 1));
    border: 2px solid transparent;
  }

  .cta-button:hover {
    opacity: 0.9;
    transform: scale(1.03);
    box-shadow: 0 4px 12px rgba(255, 159, 28, 0.3);
    border-color: rgba(255, 159, 28, 0.5);
  }

  .cta-button:active {
    transform: scale(0.98);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 1rem;
  }

  .hero-image {
    overflow: hidden;
    border-radius: 1rem;
    transition: transform 0.2s var(--ease-spring, cubic-bezier(0.4, 0, 0.2, 1));
  }

  .hero-image:hover {
    transform: scale(1.02);
  }

  .hero-image-primary {
    grid-column: 1 / -1;
    aspect-ratio: 4/3;
  }

  .hero-image-secondary,
  .hero-image-tertiary {
    aspect-ratio: 4/3;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      padding: 4rem 1.5rem;
      gap: 2rem;
    }

    .hero-content h2 {
      font-size: 2rem;
    }

    .hero-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

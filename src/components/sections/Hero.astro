---
import { Image } from "astro:assets";
import gymHero from "../../assets/images/gym1.webp";
import gymHero2 from "../../assets/images/gym14.webp";
import gymHero3 from "../../assets/images/gym15.webp";
import CTAButton from "../common/CTAButton.astro";

interface Props {
  tagline: string;
  description: string;
}

const { tagline, description } = Astro.props;
---

<section id="inicio" class="hero">
  <div class="hero-content">
    <h2>{tagline}</h2>
    <p>{description}</p>
    <CTAButton href="#servicios">Ver Servicios</CTAButton>
  </div>
  <div class="hero-grid">
    <div class="hero-image hero-image-primary media-card">
      <Image
        src={gymHero}
        alt="Gym interior"
        width={800}
        height={600}
        widths={[400, 728, 800]}
        format="webp"
        quality={75}
        loading="eager"
        fetchpriority="high"
      />
    </div>
    <div class="hero-image hero-image-secondary media-card">
      <Image
        src={gymHero2}
        alt="Training equipment"
        width={400}
        height={300}
        widths={[400, 728, 800]}
        format="webp"
        quality={75}
        loading="lazy"
        fetchpriority="low"
      />
    </div>
    <div class="hero-image hero-image-tertiary media-card">
      <Image
        src={gymHero3}
        alt="Gym atmosphere"
        width={400}
        height={300}
        widths={[400, 728, 800]}
        format="webp"
        quality={75}
        loading="lazy"
        fetchpriority="low"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    padding: 6rem 2rem;
    max-width: 1400px;
    margin: 0 auto;
    align-items: center;
    background: linear-gradient(
      135deg,
      var(--hero-overlay-start),
      var(--hero-overlay-end)
    );
    border-radius: 1rem;
  }

  .hero-content h2 {
    font-size: 3rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    line-height: 1.2;
    color: var(--color-text-base);
  }

  .hero-content p {
    font-size: 1.25rem;
    margin-bottom: 2rem;
    color: var(--color-text-base);
    opacity: 0.9;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 1rem;
  }

  .hero-image {
    border-radius: 1rem;
  }

  .hero-image-primary {
    grid-column: 1 / -1;
    aspect-ratio: 4/3;
  }

  .hero-image-secondary,
  .hero-image-tertiary {
    aspect-ratio: 4/3;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 1399px) {
    .hero {
      padding: 4rem 2rem;
      gap: 2.5rem;
    }

    .hero-content h2 {
      font-size: 2.5rem;
    }
  }

  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      padding: 4rem 1.5rem;
      gap: 2rem;
    }

    .hero-content h2 {
      font-size: 2rem;
    }

    .hero-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import { siteConfig } from '../config/site-config';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import gymHero from '../assets/images/gym1.webp';
---

<Layout title={siteConfig.siteName}>
	<header slot="header">
		<nav>
			<h1>{siteConfig.siteName}</h1>
		</nav>
	</header>

	<main>
		<section class="hero">
			<div class="hero-content">
				<h2>{siteConfig.tagline}</h2>
				<p>{siteConfig.description}</p>
				<a href="#servicios" class="cta-button">Ver Servicios</a>
			</div>
			<div class="hero-image">
				<Image 
					src={gymHero} 
					alt="Gym interior" 
					width={1200} 
					height={800} 
					loading="eager" 
				/>
			</div>
		</section>

		<section id="servicios" class="services">
			<h2>Nuestros Servicios</h2>
			<div class="services-grid">
				{siteConfig.services.map((service) => (
					<article class="service-card" id={service.id}>
						<h3>{service.title}</h3>
						<p>{service.description}</p>
					</article>
				))}
			</div>
		</section>

		<section class="info">
			<h2>Información</h2>
			<div class="info-content">
				<div class="info-item">
					<h3>Horarios</h3>
					<p>{siteConfig.contact.businessHours}</p>
				</div>
				<div class="info-item">
					<h3>Ubicación</h3>
					<p>{siteConfig.contact.address}</p>
					<a href={siteConfig.contact.googleMapsLink} target="_blank" rel="noopener noreferrer">
						Ver en Google Maps
					</a>
				</div>
			</div>
		</section>
	</main>

	<footer slot="footer">
		<p>&copy; 2024 {siteConfig.siteName}. Todos los derechos reservados.</p>
	</footer>
</Layout>

<style>
	nav {
		padding: 1.5rem 2rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	nav h1 {
		color: var(--color-accent);
		font-size: 1.5rem;
		font-weight: 700;
		margin: 0;
	}

	.hero {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		padding: 6rem 2rem;
		max-width: 1400px;
		margin: 0 auto;
		align-items: center;
	}

	.hero-content h2 {
		font-size: 3rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
		line-height: 1.2;
	}

	.hero-content p {
		font-size: 1.25rem;
		margin-bottom: 2rem;
		color: var(--color-background);
		opacity: 0.9;
	}

	.cta-button {
		display: inline-block;
		background-color: var(--color-accent);
		color: var(--color-primary);
		padding: 1rem 2rem;
		font-weight: 600;
		border-radius: 0.5rem;
		transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.2s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.2s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.cta-button:hover {
		opacity: 0.9;
		transform: translateY(-2px);
		box-shadow: 0 4px 12px rgba(255, 159, 28, 0.3);
	}

	.cta-button:active {
		transform: translateY(0);
	}

	.hero-image {
		aspect-ratio: 3/2;
		overflow: hidden;
		border-radius: 1rem;
	}

	.hero-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.services {
		padding: 6rem 2rem;
		max-width: 1400px;
		margin: 0 auto;
	}

	.services h2 {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 3rem;
		text-align: center;
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}

	.service-card {
		background-color: var(--color-background);
		padding: 2rem;
		border-radius: 0.75rem;
		aspect-ratio: 1/1;
		display: flex;
		flex-direction: column;
		justify-content: center;
		transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.2s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.service-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
	}

	.service-card h3 {
		font-size: 1.5rem;
		font-weight: 600;
		margin-bottom: 1rem;
		color: var(--color-primary);
	}

	.service-card p {
		color: var(--color-text);
		opacity: 0.8;
		line-height: 1.6;
	}

	.info {
		padding: 6rem 2rem;
		max-width: 1400px;
		margin: 0 auto;
	}

	.info h2 {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 3rem;
		text-align: center;
	}

	.info-content {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 3rem;
	}

	.info-item h3 {
		font-size: 1.25rem;
		font-weight: 600;
		margin-bottom: 1rem;
		color: var(--color-accent);
	}

	.info-item p {
		margin-bottom: 1rem;
		color: var(--color-background);
		opacity: 0.9;
	}

	footer {
		padding: 2rem;
		text-align: center;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
	}

	footer p {
		color: var(--color-background);
		opacity: 0.7;
		font-size: 0.875rem;
	}

	@media (max-width: 768px) {
		.hero {
			grid-template-columns: 1fr;
			padding: 4rem 1.5rem;
			gap: 2rem;
		}

		.hero-content h2 {
			font-size: 2rem;
		}

		.services,
		.info {
			padding: 4rem 1.5rem;
		}

		.services h2,
		.info h2 {
			font-size: 2rem;
		}

		.services-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

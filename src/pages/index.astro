---
import { siteConfig } from '../config/site-config';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import gymHero from '../assets/images/gym1.webp';
import gymHero2 from '../assets/images/gym14.webp';
import gymHero3 from '../assets/images/gym15.webp';
import coachs1 from '../assets/images/coachs1.webp';
import spinning1 from '../assets/images/spinning1.webp';
import pilates1 from '../assets/images/pilates1.webp';
import gym12 from '../assets/images/gym12.webp';

const serviceImages = {
	'coachs1.webp': coachs1,
	'spinning1.webp': spinning1,
	'pilates1.webp': pilates1,
	'gym12.webp': gym12,
};
---

<Layout title={siteConfig.siteName}>
	<header slot="header">
		<nav>
			<h1>{siteConfig.siteName}</h1>
			<ul class="nav-links">
				<li><a href="#inicio">Inicio</a></li>
				<li><a href="#conocenos">Conócenos</a></li>
				<li><a href="#servicios">Servicios</a></li>
				<li><a href="#sucursal">Sucursal</a></li>
			</ul>
		</nav>
	</header>

	<main>
		<section id="inicio" class="hero reveal-on-scroll">
			<div class="hero-content">
				<h2>{siteConfig.tagline}</h2>
				<p>{siteConfig.description}</p>
				<a href="#servicios" class="cta-button">Ver Servicios</a>
			</div>
			<div class="hero-grid">
				<div class="hero-image hero-image-primary">
					<Image 
						src={gymHero} 
						alt="Gym interior" 
						width={800} 
						height={600} 
						widths={[400, 728, 800]}
						format="webp"
						quality={75}
						loading="eager" 
					/>
				</div>
				<div class="hero-image hero-image-secondary">
					<Image 
						src={gymHero2} 
						alt="Training equipment" 
						width={400} 
						height={300} 
						loading="eager" 
					/>
				</div>
				<div class="hero-image hero-image-tertiary">
					<Image 
						src={gymHero3} 
						alt="Gym atmosphere" 
						width={400} 
						height={300} 
						widths={[400, 728, 800]}
						format="webp"
						quality={75}
						loading="eager" 
					/>
				</div>
			</div>
		</section>

		<section id="conocenos" class="about reveal-on-scroll">
			<div class="about-content">
				<div class="about-text">
					<p class="subtitle reveal-on-scroll">{siteConfig.about.history.subtitle}</p>
					<h2 class="reveal-on-scroll">{siteConfig.about.history.title.toUpperCase()}</h2>
					<p class="reveal-on-scroll">{siteConfig.about.history.text1}</p>
					<p class="reveal-on-scroll">{siteConfig.about.history.text2}</p>
				</div>
				<div class="about-image reveal-on-scroll">
					<Image 
						src={coachs1} 
						alt="Historia de Iron Pulse Gym" 
						width={800} 
						height={600} 
						loading="lazy" 
					/>
				</div>
			</div>
		</section>

		<section id="mision" class="mission reveal-on-scroll">
			<div class="mission-content">
				<div class="mission-text reveal-on-scroll">
					<h2>{siteConfig.about.mission.title}</h2>
					<p>{siteConfig.about.mission.text}</p>
				</div>
				<div class="mission-image reveal-on-scroll">
					<Image 
						src={gym12} 
						alt="Misión de Iron Pulse Gym" 
						width={800} 
						height={600} 
						loading="lazy" 
					/>
				</div>
			</div>
		</section>

		<section id="servicios" class="services reveal-on-scroll">
			<h2 class="reveal-on-scroll">Nuestros Servicios</h2>
			<div class="services-grid">
				{siteConfig.services.map((service) => (
					<article class="service-card reveal-on-scroll" id={service.id}>
						<Image 
							src={serviceImages[service.image as keyof typeof serviceImages]} 
							alt={service.title}
							width={600}
							height={450}
							loading="lazy"
							class="service-card-image"
						/>
						<div class="service-card-overlay">
							<h3>{service.title}</h3>
							<p>{service.description}</p>
						</div>
					</article>
				))}
			</div>
		</section>

		<section id="sucursal" class="sucursal reveal-on-scroll">
			<h2 class="reveal-on-scroll">Información de Sucursal</h2>
			<div class="sucursal-content">
				<div class="sucursal-item reveal-on-scroll">
					<h3>Horarios</h3>
					<p>{siteConfig.contact.businessHours}</p>
				</div>
				<div class="sucursal-item reveal-on-scroll">
					<h3>Ubicación</h3>
					<p>{siteConfig.contact.address}</p>
					<a href={siteConfig.contact.googleMapsLink} target="_blank" rel="noopener noreferrer" class="premium-button">
						Ver en Google Maps
					</a>
				</div>
			</div>
		</section>
	</main>

	<footer slot="footer">
		<p>&copy; 2026 Copyright {siteConfig.siteName}. Todos los derechos reservados./Desarrollado por consultoria Lanfranco</p>
	</footer>
</Layout>

<style>
	nav {
		padding: 1.5rem 2rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	nav h1 {
		color: var(--color-accent);
		font-size: 1.5rem;
		font-weight: 700;
		margin: 0;
	}

	.nav-links {
		display: flex;
		gap: 2rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.nav-links a {
		color: var(--color-background);
		text-decoration: none;
		font-weight: 500;
		transition: opacity 0.2s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.nav-links a:hover {
		opacity: 0.8;
	}

	.hero {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		padding: 6rem 2rem;
		max-width: 1400px;
		margin: 0 auto;
		align-items: center;
		background: linear-gradient(135deg, rgba(18, 18, 18, 0.95), rgba(18, 18, 18, 0.85));
		border-radius: 1rem;
	}

	.hero-content h2 {
		font-size: 3rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
		line-height: 1.2;
		color: var(--color-background);
	}

	.hero-content p {
		font-size: 1.25rem;
		margin-bottom: 2rem;
		color: var(--color-background);
		opacity: 0.9;
	}

	.cta-button {
		display: inline-block;
		background-color: var(--color-accent);
		color: var(--color-primary);
		padding: 1rem 2rem;
		font-weight: 600;
		border-radius: 0.5rem;
		transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.2s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.2s cubic-bezier(0.4, 0, 0.2, 1), border-color 0.2s cubic-bezier(0.4, 0, 0.2, 1);
		border: 2px solid transparent;
	}

	.cta-button:hover {
		opacity: 0.9;
		transform: scale(1.03);
		box-shadow: 0 4px 12px rgba(255, 159, 28, 0.3);
		border-color: rgba(255, 159, 28, 0.5);
	}

	.cta-button:active {
		transform: scale(0.98);
	}

	.hero-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		grid-template-rows: auto auto;
		gap: 1rem;
	}

	.hero-image {
		overflow: hidden;
		border-radius: 1rem;
		transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.hero-image:hover {
		transform: scale(1.02);
	}

	.hero-image-primary {
		grid-column: 1 / -1;
		aspect-ratio: 4/3;
	}

	.hero-image-secondary,
	.hero-image-tertiary {
		aspect-ratio: 4/3;
	}

	.hero-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.about {
		padding: 6rem 2rem;
		max-width: 1400px;
		margin: 0 auto;
	}

	.about-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	.about-text .subtitle {
		font-size: 1.125rem;
		font-style: italic;
		color: var(--color-accent);
		margin-bottom: 1rem;
	}

	.about-text h2 {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 2rem;
		color: var(--color-background);
		letter-spacing: 0.05em;
	}

	.about-text p {
		font-size: 1.125rem;
		line-height: 1.8;
		margin-bottom: 1.5rem;
		color: var(--color-background);
		opacity: 0.9;
	}

	.about-image {
		aspect-ratio: 4/3;
		overflow: hidden;
		border-radius: 1.5rem;
		transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.about-image:hover {
		transform: scale(1.02);
	}

	.about-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.mission {
		padding: 6rem 2rem;
		max-width: 1400px;
		margin: 0 auto;
		background-color: var(--color-accent);
		border-radius: 1rem;
	}

	.mission-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	.mission-text h2 {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 2rem;
		color: var(--color-primary);
	}

	.mission-text p {
		font-size: 1.125rem;
		line-height: 1.8;
		margin-bottom: 1.5rem;
		color: var(--color-primary);
	}

	.mission-image {
		aspect-ratio: 4/3;
		overflow: hidden;
		border-radius: 1.5rem;
		transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.mission-image:hover {
		transform: scale(1.02);
	}

	.mission-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.services {
		padding: 6rem 2rem;
		max-width: 1400px;
		margin: 0 auto;
	}

	.services h2 {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 3rem;
		text-align: center;
		color: var(--color-background);
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}

	.service-card {
		position: relative;
		border-radius: 1.5rem;
		aspect-ratio: 4/3;
		overflow: hidden;
		transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.service-card:hover {
		transform: scale(1.05);
	}

	.service-card-image {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.service-card:hover .service-card-image {
		transform: scale(1.05);
	}

	.service-card-overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(to top, rgba(0, 0, 0, 0.9), rgba(0, 0, 0, 0.4), transparent);
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 2rem;
	}

	.service-card h3 {
		font-size: 1.5rem;
		font-weight: 600;
		margin-bottom: 1rem;
		color: #FFFFFF;
	}

	.service-card p {
		color: rgba(255, 255, 255, 0.9);
		line-height: 1.6;
	}

	.sucursal {
		padding: 6rem 2rem;
		max-width: 1400px;
		margin: 0 auto;
	}

	.sucursal h2 {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 3rem;
		text-align: center;
		color: var(--color-background);
	}

	.sucursal-content {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 3rem;
	}

	.sucursal-item h3 {
		font-size: 1.25rem;
		font-weight: 600;
		margin-bottom: 1rem;
		color: var(--color-accent);
	}

	.sucursal-item p {
		margin-bottom: 1.5rem;
		color: var(--color-background);
		opacity: 0.9;
	}

	.premium-button {
		display: inline-block;
		background-color: var(--color-accent);
		color: var(--color-primary);
		padding: 1rem 2rem;
		font-weight: 600;
		border-radius: 0.5rem;
		transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.2s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.2s cubic-bezier(0.4, 0, 0.2, 1);
		border: 2px solid transparent;
	}

	.premium-button:hover {
		opacity: 0.9;
		transform: scale(1.03);
		box-shadow: 0 4px 12px rgba(255, 159, 28, 0.3);
		border-color: rgba(255, 159, 28, 0.5);
	}

	.premium-button:active {
		transform: scale(0.98);
	}

	footer {
		padding: 2rem;
		text-align: center;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
	}

	footer p {
		color: var(--color-background);
		opacity: 0.7;
		font-size: 0.875rem;
	}

	@media (max-width: 768px) {
		nav {
			flex-direction: column;
			gap: 1rem;
		}

		.nav-links {
			gap: 1rem;
			flex-wrap: wrap;
			justify-content: center;
		}

		.hero {
			grid-template-columns: 1fr;
			padding: 4rem 1.5rem;
			gap: 2rem;
		}

		.hero-content h2 {
			font-size: 2rem;
		}

		.hero-grid {
			grid-template-columns: 1fr;
		}

		.about,
		.mission,
		.sucursal {
			padding: 4rem 1.5rem;
		}

		.about-content,
		.mission-content {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.about-text h2,
		.mission-text h2,
		.sucursal h2 {
			font-size: 2rem;
		}

		.services-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
